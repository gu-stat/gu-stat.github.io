---
import { SITE, localePath, type Locale } from '../data/site';
import { content } from '../data/content';
interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = content[locale];
const idx = (n: number) => String(n + 1).padStart(2, '0');
---
<section class="hero">
  <div>
    <div class="kicker reveal" style="animation-delay:.05s">{t.hero.kicker}</div>
    <h1 class="hd reveal" style="animation-delay:.12s" set:html={t.hero.headlineHtml} />
    <p class="sub reveal" style="animation-delay:.22s">{t.hero.sub}</p>
    <p class="now reveal" style="animation-delay:.28s" set:html={t.hero.now} />
    <a class="cta reveal" style="animation-delay:.34s" href={SITE.cv[locale]} download>{t.hero.cta} →</a>
    <div class="social reveal" style="animation-delay:.4s">
      <a href={SITE.socials.github}>GitHub</a>
      <a href={SITE.socials.linkedin}>LinkedIn</a>
      <a href={SITE.socials.scholar}>Google Scholar</a>
    </div>
  </div>
  <div class="portrait reveal" style="animation-delay:.3s">
    <div class="frame">
      <img src="/img/portrait.jpg" alt={SITE.name} onerror="this.style.display='none'" />
    </div>
  </div>
</section>

<div class="facts reveal" style="animation-delay:.46s">
  {t.facts.map((f) => <div set:html={f} />)}
</div>

<p class="summary reveal" style="animation-delay:.5s" set:html={t.summary} />

<section class="home-sec">
  <div class="sec-head">
    <h2>{t.selected}</h2>
    <a class="see-all" href={localePath(locale, 'experience')}>{t.seeAll}</a>
  </div>
  {t.experience.slice(0, 4).map((j, i) => (
    <a class="row" href={localePath(locale, 'experience')}>
      <span class="idx">{idx(i)}</span>
      <span><span class="role">{j.role}</span><span class="org">{j.org}</span></span>
      <span class="yr">{j.period}</span>
    </a>
  ))}
</section>

<section class="home-sec">
  <div class="sec-head">
    <h2>{t.educationHeading}</h2>
    <a class="see-all" href={localePath(locale, 'education')}>{t.seeAll}</a>
  </div>
  {t.education.map((d) => (
    <a class="row mini" href={localePath(locale, 'education')}>
      <span><span class="role">{d.degree}</span><span class="org">{d.org}</span></span>
      <span class="yr">{d.period}</span>
    </a>
  ))}
</section>

<section class="home-sec">
  <div class="sec-head">
    <h2>{t.papers.heading}</h2>
    <a class="see-all" href={localePath(locale, 'publication')}>{t.seeAll}</a>
  </div>
  {t.publications.slice(0, 3).map((p) => (
    <a class="row mini" href={localePath(locale, 'publication')}>
      <span>
        <span class="role">{p.title}</span>
        <span class="org">{p.authors} · {p.year}</span>
        {p.award && <span class="award-badge">★ {p.award}</span>}
      </span>
    </a>
  ))}
</section>

<section class="home-sec">
  <div class="sec-head">
    <h2>{t.recognitionHeading}</h2>
  </div>
  <div class="feat-grid">
    {t.featured.map((f) => (
      <article class="feat-card">
        <div class="feat-kicker">{f.kicker}</div>
        <h3 class="feat-title">{f.title}</h3>
        <p class="feat-desc">{f.desc}</p>
        <a class="work-link" href={f.link} target="_blank" rel="noopener">{f.linkLabel}</a>
      </article>
    ))}
  </div>
</section>
